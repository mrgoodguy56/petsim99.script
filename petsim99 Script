-- Number formatting function  
local function FormatNumber(num)  
    num = math.floor(num)  
    local suffixes = {"", "k", "m", "b", "t"}  
    local i = 1  
    while num >= 1000 do  
        num = num / 1000  
        i = i + 1  
    end  
    return string.format("%.2f%s", num, suffixes[i])  
end

